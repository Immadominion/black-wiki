# Solana mainnet RPC (Helius dedicated endpoint). Server-side/scripts only,
# never import into client code, never commit the real value.
HELIUS_RPC=

# X API app-only bearer token. Used by the collector scripts and, in
# production, by the Scanner's /api/scan/run route (server-side only).
X_BEARER_TOKEN=

# Random secret for the Scanner's stateless pay-pass tokens.
# Generate with: openssl rand -hex 32
SCAN_SECRET=

# Optional Scanner overrides (defaults shown).
# SCAN_RECIPIENT=3hqiCoEipSWk69Mx1iPWjxjCvNRPTYEbENSBpkWtLsAG
# SCAN_PRICE_SOL=0.005
